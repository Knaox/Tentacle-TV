# ══════════════════════════════════════════════════
# TENTACLE — Environment Variables
# ══════════════════════════════════════════════════
# Copy to .env and fill in ALL required values before starting.

# ─── Database (MariaDB) — REQUIRED ───
MYSQL_ROOT_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-base64_32
MYSQL_PASSWORD=CHANGE_ME_generate_with_openssl_rand_-base64_32
# DB_USER=tentacle_user
# DB_NAME=tentacle_db

# ─── Authentication — REQUIRED ───
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_-base64_64

# ─── Server ───
PORT=3000
HOST=0.0.0.0

# ─── CORS (comma-separated origins, leave empty for permissive dev mode) ───
# CORS_ORIGINS=https://tentacle.example.com,tauri://localhost

# ─── Tentacle public URL (for Jellyfin CORS auto-injection) ───
# TENTACLE_PUBLIC_URL=https://tentacle.example.com

# ─── Local Development (not needed for Docker) ───
# VITE_BACKEND_URL=http://localhost:3001
