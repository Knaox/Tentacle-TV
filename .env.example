# ══════════════════════════════════════════════════
# TENTACLE — Environment Variables
# ══════════════════════════════════════════════════
# The docker-compose.yml works WITHOUT this file (defaults are built-in).
# Copy to .env only if you need to override values.

# ─── Database (MariaDB) ───
DATABASE_URL=mysql://tentacle_user:tentacle_password@db:3306/tentacle_db

# ─── Authentication ───
# IMPORTANT: Change this in production!
JWT_SECRET=change-me-to-a-long-random-secret

# ─── Server ───
PORT=3000
HOST=0.0.0.0

# ─── Local Development (not needed for Docker) ───
# CORS_ORIGIN=http://localhost:5173
# VITE_BACKEND_URL=http://localhost:3001
