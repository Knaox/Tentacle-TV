# ══════════════════════════════════════════════════
# TENTACLE — Configuration Locale (Dev)
# ══════════════════════════════════════════════════
# Copier ce fichier en .env et remplir les valeurs.
#
# Vite charge automatiquement :
#   .env              → toujours chargé
#   .env.production   → override quand NODE_ENV=production (vite build)
#   .env.development  → override quand NODE_ENV=development (vite dev)
#
# Les variables VITE_* sont injectées dans le frontend (publiques !).
# Les autres ne sont lues que par le backend Node.

# ─── Jellyfin Server (Backend only — NEVER expose to frontend) ───
JELLYFIN_URL=http://localhost:8096
JELLYFIN_ADMIN_API_KEY=your_admin_api_key_here

# ─── MariaDB ───
DATABASE_URL=mysql://tentacle:password@localhost:3306/tentacle

# ─── Backend Server ───
PORT=3001
JWT_SECRET=change_this_to_a_random_secret
CORS_ORIGIN=http://localhost:5173

# ─── Seerr / Overseerr ───
SEERR_URL=http://localhost:5055
SEERR_API_KEY=your_seerr_api_key_here

# ─── Frontend (VITE_ prefix = compiled into build, publicly visible) ───
VITE_JELLYFIN_URL=http://localhost:8096
VITE_BACKEND_URL=http://localhost:3001
