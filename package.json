{
  "name": "tentacle",
  "private": true,
  "version": "0.1.0",
  "description": "Premium multi-platform media client for Jellyfin",
  "scripts": {
    "dev:web": "pnpm --filter @tentacle/web dev",
    "dev:backend": "pnpm --filter @tentacle/backend dev",
    "dev:desktop": "pnpm --filter @tentacle/desktop dev",
    "dev:mobile": "pnpm --filter @tentacle/mobile start",
    "dev:tv": "pnpm --filter @tentacle/tv start",
    "build:web": "pnpm --filter @tentacle/web build",
    "build:backend": "pnpm --filter @tentacle/backend build",
    "build:desktop": "pnpm --filter @tentacle/desktop build",
    "build:tv:android": "pnpm --filter @tentacle/tv android",
    "build:mobile:android": "pnpm --filter @tentacle/mobile android",
    "build:mobile:ios": "pnpm --filter @tentacle/mobile ios",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r exec rm -rf node_modules dist .turbo && rm -rf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@10.30.2",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "bcrypt",
      "esbuild",
      "prisma"
    ]
  }
}
