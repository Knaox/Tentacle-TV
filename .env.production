# TENTACLE — Configuration Production
# ══════════════════════════════════════════════════
# Ce fichier est lu automatiquement par Vite lors de `pnpm build:*`
# Les variables VITE_* sont injectées dans le bundle frontend (publiques).

# ─── Frontend (VITE_ prefix = compilé dans le build, visible publiquement) ───
VITE_JELLYFIN_URL=https://jelly.rouge-informatique.ch
# Vide en prod = même domaine que le frontend (/api)
VITE_BACKEND_URL=
