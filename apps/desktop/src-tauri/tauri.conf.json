{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Tentacle TV",
  "version": "1.3.2",
  "identifier": "com.tentacle.media",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm --filter @tentacle-tv/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Tentacle TV",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' blob: data: https: http:; media-src 'self' blob: https: http:; connect-src 'self' https: http: http://ipc.localhost ipc:; font-src 'self' https://fonts.gstatic.com; frame-src 'self' blob: data:; child-src 'self' blob: data:; object-src 'none'; base-uri 'self'; form-action 'self';",
      "dangerousDisableAssetCspModification": true
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": "v1Compatible",
    "publisher": "Damien ROUGE",
    "resources": ["lib/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "languages": ["French", "English"],
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "14.0",
      "signingIdentity": "Developer ID Application: Damien ROUGE (96K3M57W49)",
      "entitlements": "./Entitlements.plist"
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Knaox/Tentacle-TV/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVENjcyMEE0QTFEQjdBOTQKUldTVWV0dWhwQ0JuN1ZwN0pGK2pTbFZzVStmbE4ycjh6NnF5YUVZaXY4TGRGOGwvV2lMTC9URisK"
    }
  }
}
