{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "Tentacle TV",
  "version": "0.9.1",
  "identifier": "com.tentacle.media",
  "build": {
    "frontendDist": "../../web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "",
    "beforeBuildCommand": "pnpm --filter @tentacle-tv/web build"
  },
  "app": {
    "windows": [
      {
        "title": "Tentacle TV",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "externalBin": ["binaries/mpv"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://tentacle.rouge-informatique.ch/api/update/{{target}}/{{arch}}/{{current_version}}"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM3ODcxNzFDNUZGNjI5QzcKUldUSEtmWmZIQmVITndpenNVMGl4WkhLcHBMUGQrb09vRk9EVDZHb3orR1I3aVA2WjdSZkNZZ3MK"
    }
  }
}
