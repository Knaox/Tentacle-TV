generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model InviteKey {
  id          String    @id @default(cuid())
  key         String    @unique @db.VarChar(32)
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?   @db.VarChar(255)
  usages      InviteUsage[]

  @@index([key])
  @@map("invite_keys")
}

model InviteUsage {
  id            String    @id @default(cuid())
  inviteKeyId   String
  inviteKey     InviteKey @relation(fields: [inviteKeyId], references: [id])
  jellyfinUserId String   @db.VarChar(255)
  username      String    @db.VarChar(255)
  usedAt        DateTime  @default(now())

  @@map("invite_usages")
}

model SupportTicket {
  id              String    @id @default(cuid())
  jellyfinUserId  String    @db.VarChar(255)
  username        String    @db.VarChar(255)
  subject         String    @db.VarChar(300)
  category        String    @default("general") @db.VarChar(30) // general | bug | feature | account
  status          String    @default("open") @db.VarChar(20)     // open | in_progress | resolved | closed
  mediaItemId     String?   @db.VarChar(255)  // Jellyfin item ID (episode/movie)
  mediaItemName   String?   @db.VarChar(500)  // e.g. "Breaking Bad — S1E3 — ...And the Bag's in the River"
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        TicketMessage[]

  @@index([jellyfinUserId])
  @@index([status])
  @@map("support_tickets")
}

model TicketMessage {
  id              String    @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  jellyfinUserId  String    @db.VarChar(255)
  username        String    @db.VarChar(255)
  isAdmin         Boolean   @default(false)
  body            String    @db.Text
  createdAt       DateTime  @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model Notification {
  id              String    @id @default(cuid())
  jellyfinUserId  String    @db.VarChar(255)
  type            String    @db.VarChar(30)  // ticket_reply | ticket_status | request_status
  title           String    @db.VarChar(300)
  body            String?   @db.Text
  refId           String?   @db.VarChar(255) // ticket or request ID
  read            Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([jellyfinUserId, read])
  @@map("notifications")
}

model LibraryPreference {
  id              String  @id @default(cuid())
  jellyfinUserId  String  @db.VarChar(255)
  libraryId       String  @db.VarChar(255)
  audioLang       String? @db.VarChar(10)   // ISO 639-2/B code
  subtitleLang    String? @db.VarChar(10)
  subtitleMode    String  @default("none") @db.VarChar(20) // "none" | "always" | "forced" | "signs"

  @@unique([jellyfinUserId, libraryId])
  @@index([jellyfinUserId])
  @@map("library_preferences")
}

model ServerConfig {
  key   String @id @db.VarChar(100)
  value String @db.Text

  @@map("server_config")
}

model PairingCode {
  id                    String    @id @default(cuid())
  code                  String    @unique @db.VarChar(4)
  status                String    @default("pending") @db.VarChar(20)
  deviceName            String?   @db.VarChar(100)
  deviceId              String?   @db.VarChar(255)
  jellyfinUserId        String?   @db.VarChar(255)
  username              String?   @db.VarChar(255)
  token                 String?   @db.Text
  jellyfinAccessToken   String?   @db.Text
  createdAt             DateTime  @default(now())
  expiresAt             DateTime

  @@index([expiresAt])
  @@map("pairing_codes")
}

model PairedDevice {
  id                    String    @id @default(cuid())
  name                  String    @db.VarChar(100)
  jellyfinUserId        String    @db.VarChar(255)
  username              String    @db.VarChar(255)
  tokenHash             String    @unique @db.VarChar(64)
  jellyfinAccessToken   String?   @db.Text
  lastSeen              DateTime  @default(now())
  createdAt             DateTime  @default(now())

  @@index([jellyfinUserId])
  @@index([tokenHash])
  @@map("paired_devices")
}

model SharedWatchlist {
  id              String   @id @default(cuid())
  name            String   @db.VarChar(100)
  creatorId       String   @db.VarChar(255)
  creatorUsername  String   @db.VarChar(255)
  createdAt       DateTime @default(now())
  members         SharedWatchlistMember[]
  items           SharedWatchlistItem[]

  @@index([creatorId])
  @@map("shared_watchlists")
}

model SharedWatchlistMember {
  id          String   @id @default(cuid())
  watchlistId String
  watchlist   SharedWatchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  userId      String   @db.VarChar(255)
  username    String   @db.VarChar(255)
  role        String   @default("reader") @db.VarChar(20)
  createdAt   DateTime @default(now())

  @@unique([watchlistId, userId])
  @@index([userId])
  @@map("shared_watchlist_members")
}

model SharedWatchlistItem {
  id              String   @id @default(cuid())
  watchlistId     String
  watchlist       SharedWatchlist @relation(fields: [watchlistId], references: [id], onDelete: Cascade)
  jellyfinItemId  String   @db.VarChar(255)
  addedById       String   @db.VarChar(255)
  addedByUsername  String   @db.VarChar(255)
  createdAt       DateTime @default(now())

  @@unique([watchlistId, jellyfinItemId])
  @@index([watchlistId])
  @@map("shared_watchlist_items")
}

// Plugin Seer — tables gérées par le plugin, déclarées ici pour que prisma db push ne les supprime pas
model SeerRequest {
  id               String    @id @db.VarChar(36)
  jellyfinUserId   String    @db.VarChar(255)
  username         String    @db.VarChar(255)
  mediaType        String    @db.VarChar(10)
  tmdbId           Int
  title            String    @db.VarChar(500)
  posterPath       String?   @db.VarChar(500)
  backdropPath     String?   @db.VarChar(500)
  overview         String?   @db.Text
  year             String?   @db.VarChar(10)
  seasons          Json?
  status           String    @default("queued") @db.VarChar(30)
  seerrRequestId   Int?
  seerrMediaId     Int?
  seerrMediaStatus Int?
  retryCount       Int       @default(0)
  maxRetries       Int       @default(10)
  lastError        String?   @db.Text
  priority         Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  sentAt           DateTime?
  completedAt      DateTime?

  @@index([jellyfinUserId])
  @@index([status])
  @@index([status, priority(sort: Desc), createdAt])
  @@map("seer_requests")
}

model SeerCleanupQueue {
  id             String    @id @db.VarChar(36)
  action         String    @db.VarChar(20)
  mediaType      String    @db.VarChar(10)
  tmdbId         Int
  title          String    @db.VarChar(500)
  seerrRequestId Int?
  seerrMediaId   Int?
  deleteFiles    Boolean   @default(true)
  retryCount     Int       @default(0)
  maxRetries     Int       @default(20)
  lastError      String?   @db.Text
  status         String    @default("pending") @db.VarChar(20)
  createdAt      DateTime  @default(now())
  nextRetryAt    DateTime  @default(now())

  @@index([status, nextRetryAt])
  @@map("seer_cleanup_queue")
}
