generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model InviteKey {
  id          String    @id @default(cuid())
  key         String    @unique @db.VarChar(32)
  maxUses     Int       @default(1)
  currentUses Int       @default(0)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  createdBy   String?   @db.VarChar(255)
  usages      InviteUsage[]

  @@index([key])
  @@map("invite_keys")
}

model InviteUsage {
  id            String    @id @default(cuid())
  inviteKeyId   String
  inviteKey     InviteKey @relation(fields: [inviteKeyId], references: [id])
  jellyfinUserId String   @db.VarChar(255)
  username      String    @db.VarChar(255)
  usedAt        DateTime  @default(now())

  @@map("invite_usages")
}

model MediaRequest {
  id              String    @id @default(cuid())
  jellyfinUserId  String    @db.VarChar(255)
  username        String    @db.VarChar(255)
  mediaType       String    @db.VarChar(10)   // "movie" | "tv"
  tmdbId          Int
  title           String    @db.VarChar(500)
  posterPath      String?   @db.VarChar(500)
  status          String    @default("pending") @db.VarChar(20) // pending | submitted | approved | available | failed | declined
  seerrRequestId  Int?
  seerrMediaId    Int?
  retryCount      Int       @default(0)
  lastError       String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([jellyfinUserId])
  @@index([status])
  @@index([tmdbId, mediaType])
  @@map("media_requests")
}

model SupportTicket {
  id              String    @id @default(cuid())
  jellyfinUserId  String    @db.VarChar(255)
  username        String    @db.VarChar(255)
  subject         String    @db.VarChar(300)
  category        String    @default("general") @db.VarChar(30) // general | bug | feature | account
  status          String    @default("open") @db.VarChar(20)     // open | in_progress | resolved | closed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  messages        TicketMessage[]

  @@index([jellyfinUserId])
  @@index([status])
  @@map("support_tickets")
}

model TicketMessage {
  id              String    @id @default(cuid())
  ticketId        String
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  jellyfinUserId  String    @db.VarChar(255)
  username        String    @db.VarChar(255)
  isAdmin         Boolean   @default(false)
  body            String    @db.Text
  createdAt       DateTime  @default(now())

  @@index([ticketId])
  @@map("ticket_messages")
}

model Notification {
  id              String    @id @default(cuid())
  jellyfinUserId  String    @db.VarChar(255)
  type            String    @db.VarChar(30)  // ticket_reply | ticket_status | request_status
  title           String    @db.VarChar(300)
  body            String?   @db.Text
  refId           String?   @db.VarChar(255) // ticket or request ID
  read            Boolean   @default(false)
  createdAt       DateTime  @default(now())

  @@index([jellyfinUserId, read])
  @@map("notifications")
}

model LibraryPreference {
  id              String  @id @default(cuid())
  jellyfinUserId  String  @db.VarChar(255)
  libraryId       String  @db.VarChar(255)
  audioLang       String? @db.VarChar(10)   // ISO 639-2/B code
  subtitleLang    String? @db.VarChar(10)
  subtitleMode    String  @default("none") @db.VarChar(20) // "none" | "always" | "forced" | "signs"

  @@unique([jellyfinUserId, libraryId])
  @@index([jellyfinUserId])
  @@map("library_preferences")
}
