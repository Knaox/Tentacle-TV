#!/bin/bash
# ══════════════════════════════════════════════════════════════
# TENTACLE — Hook post-receive (Monorepo pnpm)
# Emplacement: /var/repo/tentacle.git/hooks/post-receive
# Déclenché par: git push integration main
# ══════════════════════════════════════════════════════════════
set -e

echo "================================================="
echo "  Démarrage du déploiement de TENTACLE"
echo "================================================="

# ─── Variables ───
GIT_REPO="/var/repo/tentacle.git"
SOURCE_DIR="/var/repo/tentacle-source"
WEB_DIR="/var/www/tentacle"
BACKEND_ENV="/var/repo/tentacle-source/apps/backend/.env"
BACKEND_SERVICE="tentacle-backend"

# ─── 1. Extraction du code ───
echo "[1/6] Extraction du code source..."
mkdir -p "$SOURCE_DIR"
git --work-tree="$SOURCE_DIR" --git-dir="$GIT_REPO" checkout -f main
cd "$SOURCE_DIR"

# Auto-update du hook
if [ -f "$SOURCE_DIR/deploy/post-receive" ]; then
    cp "$SOURCE_DIR/deploy/post-receive" "$GIT_REPO/hooks/post-receive"
    chmod +x "$GIT_REPO/hooks/post-receive"
    echo "  Hook mis à jour"
fi

# ─── 2. Vérification pnpm ───
if ! command -v pnpm &> /dev/null; then
    echo "[2/6] Installation de pnpm..."
    npm install -g pnpm
else
    echo "[2/6] pnpm OK ($(pnpm -v))"
fi

# ─── 3. Installation des dépendances ───
echo "[3/6] Installation des dépendances monorepo..."
pnpm install --frozen-lockfile

# ─── 4. Chargement du .env + Prisma generate ───
echo "[4/6] Configuration production + Prisma..."
if [ -f "$BACKEND_ENV" ]; then
    set -a && source "$BACKEND_ENV" && set +a
    echo "  .env chargé"
else
    echo "  ATTENTION: $BACKEND_ENV introuvable !"
fi

cd "$SOURCE_DIR/apps/backend"
npx prisma generate
npx prisma db push --accept-data-loss 2>/dev/null || echo "  (Prisma push skipped — vérifier connexion DB)"
cd "$SOURCE_DIR"

# ─── 5. Build frontend + backend ───
echo "[5/6] Compilation..."
pnpm build:web
pnpm build:backend

# Déploiement frontend
mkdir -p "$WEB_DIR"
rm -rf "${WEB_DIR:?}"/*
cp -r apps/web/dist/* "$WEB_DIR"/
chown -R www-data:www-data "$WEB_DIR"
echo "  Frontend déployé dans $WEB_DIR"

# Permissions monorepo (le backend tourne depuis ici)
chown -R www-data:www-data "$SOURCE_DIR"

# ─── 6. Redémarrage du backend ───
echo "[6/6] Redémarrage du backend..."
if systemctl is-enabled --quiet "$BACKEND_SERVICE" 2>/dev/null; then
    systemctl restart "$BACKEND_SERVICE"
    sleep 2
    if systemctl is-active --quiet "$BACKEND_SERVICE"; then
        echo "  Backend démarré !"
    else
        echo "  ERREUR: journalctl -u $BACKEND_SERVICE -n 50"
    fi
else
    echo "  Service pas encore activé."
    echo "  sudo systemctl enable --now $BACKEND_SERVICE"
fi

echo "================================================="
echo "  Déploiement terminé !"
echo "  Frontend: https://tentacle.rouge-informatique.ch"
echo "  Backend:  https://tentacle.rouge-informatique.ch/api/health"
echo "================================================="
