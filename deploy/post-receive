#!/bin/bash
# ══════════════════════════════════════════════════════════════
# TENTACLE — Hook post-receive (Monorepo pnpm)
# Emplacement: /var/repo/tentacle.git/hooks/post-receive
# Déclenché par: git push integration main
# ══════════════════════════════════════════════════════════════
set -e

echo "================================================="
echo "  Démarrage du déploiement de TENTACLE"
echo "================================================="

# ─── Variables ───
GIT_REPO="/var/repo/tentacle.git"
SOURCE_DIR="/var/repo/tentacle-source"
WEB_DIR="/var/www/tentacle"
BACKEND_DIR="/opt/tentacle-backend"
BACKEND_ENV="/opt/tentacle-backend/.env"
BACKEND_SERVICE="tentacle-backend"

# ─── 1. Extraction du code ───
echo "[1/7] Extraction du code source..."
mkdir -p "$SOURCE_DIR"
git --work-tree="$SOURCE_DIR" --git-dir="$GIT_REPO" checkout -f main
cd "$SOURCE_DIR"

# ─── 2. Vérification pnpm ───
if ! command -v pnpm &> /dev/null; then
    echo "[2/7] Installation de pnpm..."
    npm install -g pnpm
else
    echo "[2/7] pnpm OK ($(pnpm -v))"
fi

# ─── 3. Installation des dépendances ───
echo "[3/7] Installation des dépendances monorepo..."
pnpm install --frozen-lockfile

# ─── 4. Chargement du .env de production pour le build frontend ───
# Les variables VITE_ doivent être présentes au moment du build
echo "[4/7] Chargement de la config production..."
if [ -f "$BACKEND_ENV" ]; then
    set -a
    source "$BACKEND_ENV"
    set +a
    echo "  .env chargé depuis $BACKEND_ENV"
else
    echo "  ATTENTION: $BACKEND_ENV introuvable ! Le build utilisera les valeurs par défaut."
fi

# ─── 5. Génération Prisma + Build ───
echo "[5/7] Compilation du frontend Web + backend..."
# Prisma generate doit tourner AVANT le build backend (types)
cd "$SOURCE_DIR/apps/backend"
npx prisma generate
cd "$SOURCE_DIR"

pnpm build:web

# Déploiement des fichiers statiques
mkdir -p "$WEB_DIR"
rm -rf "${WEB_DIR:?}"/*
cp -r apps/web/dist/* "$WEB_DIR"/
chown -R www-data:www-data "$WEB_DIR"
echo "  Frontend déployé dans $WEB_DIR"

# ─── 6. Build du Backend ───
echo "[6/7] Compilation et déploiement du backend..."
pnpm build:backend

# Copie des fichiers compilés
mkdir -p "$BACKEND_DIR"
rsync -a --delete apps/backend/dist/ "$BACKEND_DIR/dist/"
rsync -a apps/backend/prisma/ "$BACKEND_DIR/prisma/"
cp apps/backend/package.json "$BACKEND_DIR/package.json"
cp pnpm-lock.yaml "$BACKEND_DIR/pnpm-lock.yaml" 2>/dev/null || true

# Installer les dépendances de production du backend
cd "$BACKEND_DIR"
npm install --omit=dev --ignore-scripts 2>/dev/null || true

# Générer le client Prisma
npx prisma generate 2>/dev/null || echo "  (Prisma generate skipped)"

# Appliquer le schéma à la DB
if [ -f "$BACKEND_ENV" ]; then
    set -a && source "$BACKEND_ENV" && set +a
    npx prisma db push --accept-data-loss 2>/dev/null || echo "  (Prisma push skipped — vérifier la connexion DB)"
fi

chown -R www-data:www-data "$BACKEND_DIR"

# ─── 7. Redémarrage du service backend ───
echo "[7/7] Redémarrage du backend..."
if systemctl is-enabled --quiet "$BACKEND_SERVICE" 2>/dev/null; then
    systemctl restart "$BACKEND_SERVICE"
    sleep 2
    if systemctl is-active --quiet "$BACKEND_SERVICE"; then
        echo "  Backend démarré avec succès !"
    else
        echo "  ERREUR: Le backend n'a pas démarré. Vérifier avec:"
        echo "  journalctl -u $BACKEND_SERVICE -n 50"
    fi
else
    echo "  Service $BACKEND_SERVICE pas encore activé. Premier déploiement ?"
    echo "  Exécuter: sudo systemctl enable --now $BACKEND_SERVICE"
fi

echo "================================================="
echo "  Déploiement terminé ! Tentacle est en ligne."
echo "  Frontend: https://tentacle.rouge-informatique.ch"
echo "  Backend:  https://tentacle.rouge-informatique.ch/api/health"
echo "================================================="
